.search-row { margin-top: 24rpx; }
.sort-row { display:flex; gap: 12rpx; flex-wrap:wrap; margin-top: 18rpx; }
.sort { padding: 12rpx 18rpx; border-radius:999rpx; background:#fff6ee; color:#8a8076; font-size:24rpx; }
.sort.active { background:#e9672e; color:#fff; font-weight:800; }
.stats { display:grid; grid-template-columns: 1fr 1fr; text-align:center; }
.stats view { display:flex; flex-direction:column; gap:6rpx; }
.num { font-size:34rpx; font-weight:900; }
.resource-main { flex:1; min-width:0; }
.top-line { align-items:flex-start; gap:12rpx; }
.title-line { flex:1; }
.remove { flex:none; padding: 8rpx 16rpx; border-radius:999rpx; background:#fff1e7; color:#d44b1c; font-size:22rpx; font-weight:800; }
.meta-row { display:flex; align-items:center; gap:12rpx; margin-top:12rpx; flex-wrap:wrap; }
.stars { color:#f5a524; font-size:24rpx; letter-spacing:1rpx; }
.tag-line { margin-top:10rpx; }
.author-line { display:flex; align-items:center; gap:10rpx; margin-top:8rpx; }
.mini-avatar { width:36rpx; height:36rpx; border-radius:50%; background:#f7eadc; }
