.page-head { margin-bottom: 24rpx; }
.ai-card { border-radius: 30rpx; padding: 28rpx; color:#fff; background: linear-gradient(135deg,#25211d,#e9672e); }
.ai-card .muted { color: rgba(255,255,255,.72); margin-top: 8rpx; }
.ai-text { box-sizing:border-box; width:100%; height:150rpx; background: rgba(255,255,255,.14); color:#fff; border-radius: 22rpx; padding: 20rpx; margin: 20rpx 0; }
.form .label { margin: 26rpx 0 12rpx; font-weight: 750; color:#5f554d; }
.form .label:first-child { margin-top:0; }
.url-row { display:grid; grid-template-columns: 1fr 116rpx; gap: 14rpx; align-items:center; }
.check-btn { height:84rpx; border-radius:22rpx; display:flex; align-items:center; justify-content:center; background:#fff1e7; color:#e9672e; font-weight:800; }
.ok { color:#20a05a; margin-top:10rpx; }
.bad { color:#d53a2f; margin-top:10rpx; }
.tag-wrap { margin-top: 14rpx; }
.free-note { margin-top: 26rpx; padding: 18rpx; background:#fff7ed; color:#8b5a3c; border-radius:20rpx; font-size:24rpx; }
.submit { margin-top: 24rpx; }
