.stats { display:grid; grid-template-columns: repeat(5, 1fr); text-align:center; gap: 8rpx; }
.stats view { display:flex; flex-direction:column; gap:6rpx; }
.num { font-size:32rpx; font-weight:900; }
.ok-num { color:#16a34a; }
.warn-num { color:#d97706; }
.bad-num { color:#dc2626; }
.search-row { display:grid; grid-template-columns: 1fr 120rpx; gap: 16rpx; }
.search-btn { height:84rpx; border-radius:22rpx; background:#28231f; color:#fff; display:flex; align-items:center; justify-content:center; font-weight:800; }
.filter, .sort-row { display:flex; gap:12rpx; flex-wrap:wrap; margin-top:18rpx; }
.tab, .sort { padding:12rpx 18rpx; border-radius:999rpx; background:#fff; color:#8a8076; border:1rpx solid #f0e3d4; font-size:24rpx; }
.tab.active { background:#28231f; color:#fff; }
.sort { background:#fff6ee; border:0; }
.sort.active { background:#e9672e; color:#fff; font-weight:800; }
.resource-main { flex:1; min-width:0; }
.top-line { align-items:flex-start; gap:12rpx; }
.title-line { flex:1; }
.status { flex:none; padding: 8rpx 14rpx; border-radius:999rpx; font-size:22rpx; font-weight:800; background:#eee; color:#666; }
.status-approved { background:#dcfce7; color:#15803d; }
.status-pending { background:#fef3c7; color:#b45309; }
.status-rejected { background:#fee2e2; color:#b91c1c; }
.meta-row { display:flex; align-items:center; gap:12rpx; margin-top:12rpx; flex-wrap:wrap; }
.stars { color:#f5a524; font-size:24rpx; letter-spacing:1rpx; }
.tag-line { margin-top:10rpx; }
.reject-box { margin-top:12rpx; padding:14rpx; border-radius:16rpx; background:#fff1f2; color:#be123c; font-size:24rpx; }
.op-row { margin-top:14rpx; display:flex; align-items:center; justify-content:space-between; gap:12rpx; }
.delete-btn { padding:10rpx 18rpx; border-radius:999rpx; background:#fff1e7; color:#d44b1c; font-size:24rpx; font-weight:800; }

.price.paid { background:#28231f; color:#fff; }
