<view class="container">
  <view class="between"><view class="title">我的上传</view><button class="share-btn" open-type="share">分享</button></view>
  <view class="stats card section">
    <view><text class="num">{{stats.total || 0}}</text><text class="muted small">全部</text></view>
    <view><text class="num ok-num">{{stats.approved || 0}}</text><text class="muted small">已通过</text></view>
    <view><text class="num warn-num">{{stats.pending || 0}}</text><text class="muted small">待审核</text></view>
    <view><text class="num bad-num">{{stats.rejected || 0}}</text><text class="muted small">已拒绝</text></view>
    <view><text class="num">{{stats.totalAccess || 0}}</text><text class="muted small">总访问</text></view>
  </view>

  <view class="search-row section">
    <input class="input" value="{{search}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="submitSearch" placeholder="搜索我的上传" />
    <view class="search-btn" bindtap="submitSearch">搜索</view>
  </view>

  <view class="filter">
    <text class="tab {{status === '' ? 'active' : ''}}" data-status="" bindtap="setStatus">全部</text>
    <text class="tab {{status === 'approved' ? 'active' : ''}}" data-status="approved" bindtap="setStatus">已通过</text>
    <text class="tab {{status === 'pending' ? 'active' : ''}}" data-status="pending" bindtap="setStatus">待审核</text>
    <text class="tab {{status === 'rejected' ? 'active' : ''}}" data-status="rejected" bindtap="setStatus">已拒绝</text>
  </view>
  <view class="sort-row">
    <text class="sort {{sort === 'latest' ? 'active' : ''}}" data-sort="latest" bindtap="setSort">最新</text>
    <text class="sort {{sort === 'popular' ? 'active' : ''}}" data-sort="popular" bindtap="setSort">热门</text>
    <text class="sort {{sort === 'rating' ? 'active' : ''}}" data-sort="rating" bindtap="setSort">评分</text>
    <text class="sort {{sort === 'views' ? 'active' : ''}}" data-sort="views" bindtap="setSort">浏览</text>
  </view>

  <view class="card section">
    <block wx:if="{{resources.length}}">
      <view wx:for="{{resources}}" wx:key="uuid" class="resource-item" bindtap="goDetail" data-id="{{item.uuid}}">
        <view class="resource-cover">{{item.initial}}</view>
        <view class="resource-main">
          <view class="between top-line">
            <view class="h3 line-1 title-line">{{item.title}}</view>
            <text class="status status-{{item.status}}">{{item.status_text}}</text>
          </view>
          <view class="muted small line-2">{{item.description}}</view>
          <view class="meta-row">
            <text class="stars">{{item.rating_stars}}</text>
            <text class="muted small">{{item.display_rating}} · {{item.rating_count || 0}}评价</text>
            <text class="muted small">访问 {{item.access_text}}</text>
            <text class="muted small">浏览 {{item.view_text}}</text>
          </view>
          <view class="tag-line"><text class="badge">{{item.category_name}}</text><text class="badge">{{item.created_text}}</text><text class="badge">免费</text></view>
          <view wx:if="{{item.status === 'rejected' && item.rejection_reason}}" class="reject-box">拒绝原因：{{item.rejection_reason}}</view>
          <view class="op-row">
            <view class="small muted">审核通过后会在资源库展示</view>
            <view class="delete-btn" catchtap="deleteResource" data-id="{{item.uuid}}">删除</view>
          </view>
        </view>
      </view>
    </block>
    <view wx:elif="{{loading}}" class="empty">加载中...</view>
    <view wx:else class="empty">暂无上传</view>
  </view>
</view>
