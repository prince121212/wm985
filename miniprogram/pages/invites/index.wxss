.invite { background: linear-gradient(135deg,#fff7ed,#fff); }
.desc { line-height:1.7; margin: 18rpx 0 26rpx; }
.rule { margin-top: 14rpx; line-height:1.6; }
.summary { display:grid; grid-template-columns: 1fr 1fr; gap: 16rpx; text-align:center; }
.summary view { display:flex; flex-direction:column; gap:8rpx; }
.num { font-size:42rpx; font-weight:900; color:#e9672e; }
.invite-row { display:flex; gap:18rpx; align-items:center; padding:24rpx 0; border-bottom:1rpx solid #f0e3d4; }
.invite-row:last-child { border-bottom:0; }
.avatar { width:78rpx; height:78rpx; border-radius:50%; background:#f7eadc; }
