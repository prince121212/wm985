.hero {
  position: relative;
  overflow: hidden;
  padding: 38rpx;
  border-radius: 40rpx;
  color: #fff;
  background: radial-gradient(circle at 90% 10%, rgba(255,255,255,.26), transparent 28%), linear-gradient(135deg,#241f1a,#df5520 62%, #ff9a45);
  box-shadow: 0 22rpx 48rpx rgba(223,85,32,.24);
}
.hero::after { content:""; position:absolute; right:-80rpx; bottom:-120rpx; width:260rpx; height:260rpx; border-radius:50%; background:rgba(255,255,255,.12); }
.hello { opacity: .78; font-size: 24rpx; font-weight:700; }
.hero-title { font-size: 52rpx; font-weight: 950; margin-top: 8rpx; letter-spacing: -.5rpx; }
.search { margin-top: 30rpx; background: #fff; color: #81756a; border-radius: 26rpx; padding: 24rpx 26rpx; font-weight:700; box-shadow: 0 12rpx 24rpx rgba(34,25,18,.12); }
.reward { margin-top: 18rpx; padding: 18rpx 20rpx; border-radius: 24rpx; background: rgba(255,255,255,.16); font-size: 24rpx; line-height:1.5; }
.category-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap: 18rpx; margin-top: 18rpx; }
.category-card { background:#fff; border-radius: 28rpx; padding: 26rpx 12rpx; text-align:center; border:1rpx solid #f0e3d4; box-shadow: 0 10rpx 24rpx rgba(53,38,24,.05); }
.category-icon { width: 74rpx; height: 74rpx; border-radius: 24rpx; margin:0 auto 14rpx; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:900; background: linear-gradient(135deg,#ff7a32,#f7b35d); box-shadow:0 10rpx 20rpx rgba(233,103,46,.18); }
.tag-row { display:flex; flex-wrap:wrap; gap: 8rpx; margin-top: 16rpx; }
.resource-cover.alt { background: linear-gradient(135deg,#3f7bff,#87cdfd); }
.meta-row { display:flex; align-items:center; gap:10rpx; margin-top:10rpx; flex-wrap:wrap; }
.stars { color:#f5a524; font-size:22rpx; letter-spacing:1rpx; }
.more-link { color:#e9672e; font-weight:900; font-size:24rpx; }
.price.paid { background:#241f1a; color:#fff; }
