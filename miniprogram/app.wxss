page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff7ef 0%, #fffdf9 42%, #f8fbff 100%);
  color: #241f1a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft Yahei", sans-serif;
  font-size: 28rpx;
}
.container { padding: 30rpx; padding-bottom: 56rpx; }
.card {
  background: rgba(255,255,255,.94);
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 16rpx 42rpx rgba(53, 38, 24, .08);
  border: 1rpx solid rgba(238, 222, 206, .82);
  backdrop-filter: blur(12rpx);
}
.section { margin-top: 30rpx; }
.row { display: flex; align-items: center; }
.between { display: flex; align-items: center; justify-content: space-between; }
.title { font-size: 42rpx; font-weight: 900; color: #241f1a; letter-spacing: -.5rpx; }
.h2 { font-size: 34rpx; font-weight: 900; color: #241f1a; }
.h3 { font-size: 30rpx; font-weight: 800; color: #241f1a; }
.muted { color: #81756a; }
.small { font-size: 24rpx; }
.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1e7;
  color: #96542f;
  font-size: 22rpx;
  font-weight: 700;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}
.badge.paid, .price.paid { background: #241f1a; color: #fff; }
.primary-btn {
  height: 90rpx;
  border-radius: 26rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff7a32, #df5520 48%, #bd3f18);
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 28rpx rgba(223,85,32,.24);
}
.ghost-btn {
  height: 82rpx;
  border-radius: 24rpx;
  color: #241f1a;
  background: #fff8f2;
  border: 1rpx solid #f0d8c4;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-btn {
  min-width: 104rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.92);
  color: #e9672e;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(84,53,24,.10);
  border: 1rpx solid rgba(255,255,255,.65);
}
.input, .textarea, .picker {
  width: 100%;
  box-sizing: border-box;
  background: #fff;
  border: 1rpx solid #eedfce;
  border-radius: 24rpx;
  padding: 22rpx 24rpx;
  min-height: 86rpx;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,.8);
}
.textarea { height: 150rpx; }
.empty { text-align: center; color: #8a8076; padding: 80rpx 24rpx; }
.resource-item { display: flex; gap: 22rpx; padding: 26rpx 0; border-bottom: 1rpx solid #f0e3d4; }
.resource-item:last-child { border-bottom: 0; }
.resource-cover {
  width: 104rpx;
  height: 104rpx;
  flex: none;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ff7a32, #f7b35d);
  color: #fff;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:900;
  box-shadow: 0 12rpx 24rpx rgba(233,103,46,.20);
}
.line-1 { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.line-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
