page {
  min-height: 100vh;
  background: #fffaf4;
  color: #28231f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft Yahei", sans-serif;
  font-size: 28rpx;
}
.container { padding: 28rpx; padding-bottom: 48rpx; }
.card { background: #fff; border-radius: 28rpx; padding: 28rpx; box-shadow: 0 10rpx 28rpx rgba(84,53,24,.06); border: 1rpx solid #f0e3d4; }
.section { margin-top: 28rpx; }
.row { display: flex; align-items: center; }
.between { display: flex; align-items: center; justify-content: space-between; }
.title { font-size: 40rpx; font-weight: 800; color: #25211d; }
.h2 { font-size: 34rpx; font-weight: 800; color: #25211d; }
.h3 { font-size: 30rpx; font-weight: 750; color: #25211d; }
.muted { color: #8a8076; }
.small { font-size: 24rpx; }
.badge { display: inline-flex; align-items: center; padding: 6rpx 14rpx; border-radius: 999rpx; background: #fff1e7; color: #9a5a34; font-size: 22rpx; margin-right: 8rpx; margin-bottom: 8rpx; }
.primary-btn { height: 88rpx; border-radius: 24rpx; color: #fff; background: linear-gradient(135deg, #e9672e, #bd4a1d); font-weight: 800; display: flex; align-items: center; justify-content: center; }
.ghost-btn { height: 80rpx; border-radius: 22rpx; color: #28231f; background: #fff6ee; border: 1rpx solid #f0d8c4; font-weight: 750; display: flex; align-items: center; justify-content: center; }
.share-btn { min-width: 104rpx; height: 64rpx; line-height: 64rpx; padding: 0 22rpx; border-radius: 999rpx; background: #fff; color: #e9672e; font-size: 24rpx; font-weight: 800; box-shadow: 0 8rpx 18rpx rgba(84,53,24,.08); }
.input, .textarea, .picker { width: 100%; box-sizing: border-box; background: #fff; border: 1rpx solid #eee0d0; border-radius: 22rpx; padding: 22rpx 24rpx; min-height: 84rpx; }
.textarea { height: 150rpx; }
.empty { text-align: center; color: #8a8076; padding: 80rpx 24rpx; }
.resource-item { display: flex; gap: 22rpx; padding: 24rpx 0; border-bottom: 1rpx solid #f0e3d4; }
.resource-item:last-child { border-bottom: 0; }
.resource-cover { width: 100rpx; height: 100rpx; flex: none; border-radius: 24rpx; background: linear-gradient(135deg, #e9672e, #f7b35d); color: #fff; display:flex; align-items:center; justify-content:center; font-weight:900; }
.line-1 { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.line-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
