.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  pointer-events: none;
}

.tab-safe {
  box-sizing: border-box;
  padding: 0 28rpx 20rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.tabbar {
  height: 112rpx;
  padding: 12rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .96);
  border: 1rpx solid rgba(238, 222, 206, .9);
  box-shadow: 0 18rpx 48rpx rgba(53, 38, 24, .16), inset 0 1rpx 0 rgba(255, 255, 255, .9);
  display: flex;
  align-items: center;
  backdrop-filter: blur(18rpx);
  pointer-events: auto;
}

.tab-item {
  position: relative;
  flex: 1;
  height: 88rpx;
  min-width: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a8076;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: .5rpx;
  transition: all .18s ease;
}

.tab-item.active {
  color: #e9672e;
  background: linear-gradient(135deg, #fff1e7 0%, #fff8f2 100%);
  box-shadow: inset 0 0 0 1rpx rgba(233, 103, 46, .12), 0 10rpx 22rpx rgba(233, 103, 46, .1);
}

.tab-text {
  line-height: 1;
}

.active-mark {
  position: absolute;
  left: 50%;
  bottom: 12rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff7a32, #e9672e);
  transform: translateX(-50%);
}
