<view class="tab-shell">
  <view class="tab-safe">
    <view class="tabbar">
      <view
        wx:for="{{list}}"
        wx:key="pagePath"
        data-index="{{index}}"
        class="tab-item {{selected === index ? 'active' : ''}}"
        bindtap="switchTab"
      >
        <view class="tab-text">{{item.text}}</view>
        <view wx:if="{{selected === index}}" class="active-mark"></view>
      </view>
    </view>
  </view>
</view>
